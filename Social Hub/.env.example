# SocialHub environment example
# Copy this file to .env and keep the real file out of version control.

# Google AI
GOOGLE_API_KEY=your-google-api-key
NEXT_PUBLIC_GEMINI_API_KEY=

# Shared cloud environment selection
# Use test for day-to-day development and QA, production for the live deployment.
APP_ENV=test

# Supabase project settings
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_publishable_key
SUPABASE_ANON_KEY=your_legacy_anon_key_if_needed
SUPABASE_SCHEMA=test
DATABASE_SCHEMA=test
DATABASE_TABLE_PREFIX=socialhub_

# Required: shared backend persistence always uses the Supabase connection pooler URL
SUPABASE_DB_URL=postgresql://postgres.your-project-ref:your-db-password@aws-0-your-region.pooler.supabase.com:5432/postgres
DATABASE_URL=

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8000/auth/linkedin/callback

# Instagram OAuth
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=http://localhost:8000/auth/instagram/callback

# App secret for cookies / CSRF
APP_SECRET_KEY=change-me-in-production-use-a-long-random-string

# Schedule defaults
POSTING_DAYS=1,3
POSTING_HOUR=9
POSTING_MINUTE=0
