{
  "_info": {
    "title": "Momentum Marketing OS – Kampagnen-Import-Vorlage",
    "description": "Vorlage zum Import einer einzelnen Kampagne. Füllen Sie die Felder im 'importData'-Block aus und importieren Sie die Datei unter Kampagnen → Import/Export.",
    "version": "1.0.0"
  },

  "questionnaire": [
    { "key": "campaign.name", "question": "Kampagnenname?", "required": true, "value": "" },
