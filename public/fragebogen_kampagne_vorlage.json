    { "key": "campaign.startDate", "question": "Startdatum (YYYY-MM-DD)?", "required": true, "value": "" },
    { "key": "campaign.endDate", "question": "Enddatum (YYYY-MM-DD)?", "required": true, "value": "" },
    { "key": "campaign.budget", "question": "Gesamtbudget in EUR?", "required": true, "value": 0 },
    { "key": "campaign.spent", "question": "Bereits ausgegeben?", "required": false, "value": 0 },
    { "key": "campaign.channels", "question": "Kanäle? (Array, z.B. [\"Social Media\", \"SEA\"])", "required": false, "value": [] },
    { "key": "campaign.description", "question": "Kurzbeschreibung der Kampagne?", "required": false, "value": "" },
    { "key": "campaign.masterPrompt", "question": "KI-Master-Prompt für Content-Generierung?", "required": false, "value": "" },
    { "key": "campaign.targetAudiences", "question": "Zielgruppen-Namen? (Array)", "required": false, "value": [] },
    { "key": "campaign.campaignKeywords", "question": "Kampagnen-Keywords? (Array)", "required": false, "value": [] },
    { "key": "campaign.progress", "question": "Fortschritt in % (0-100)?", "required": false, "value": 0 }
  ],

  "importData": {
